{
  "name": "podwatch",
  "version": "1.0.0",
  "description": "Cost monitoring, budget enforcement, and security alerts for OpenClaw agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "podwatch": "./bin/podwatch.js"
  },
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "bin/",
    "lib/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "openclaw": {
    "plugin": true,
    "extensions": ["./dist/index.js"]
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "monitoring",
    "cost-tracking",
    "security",
    "observability",
    "budget-enforcement"
  ],
  "author": "Rafael Urena",
  "license": "MIT",
  "homepage": "https://podwatch.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaime-perez-dev/podwatch-plugin"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "typescript": "^5.7.0"
  }
}

{
  "name": "podwatch",
  "version": "1.1.8",
  "description": "Security monitoring, cost tracking, and observability for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "podwatch": "./bin/podwatch.js"
  },
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "bin/",
    "lib/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "openclaw": {
    "plugin": true,
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agent",
    "monitoring",
    "cost-tracking",
    "security",
    "observability",
    "budget-enforcement"
  ],
  "author": "Rafael Urena",
  "license": "BSD-3-Clause",
  "homepage": "https://podwatch.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/podwatch/podwatch-plugin"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
